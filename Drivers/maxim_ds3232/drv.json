      "len": 7,
      "fields": [
        { "name": "seconds", "byte": 0, "mask": 127, "bcd": true },
        { "name": "minutes", "byte": 1, "mask": 127, "bcd": true },
        { "name": "hours",   "byte": 2, "mask":  63, "bcd": true },
        { "name": "dow",     "byte": 3, "mask":   7, "bcd": false },
        { "name": "day",     "byte": 4, "mask":  63, "bcd": true },
        { "name": "month",   "byte": 5, "mask":  31, "bcd": true },
